# Anthropic
ANTHROPIC_API_KEY=

# Google (Gmail + Calendar). OAuth client downloaded from console.cloud.google.com
GOOGLE_CREDENTIALS_PATH=
# Comma-separated Gmail addresses to check. Each gets its own browser sign-in
# and its own cached google_token_<email>.json. Leave blank for a single account.
GMAIL_ACCOUNTS=me@gmail.com,work@gmail.com

# Microsoft Graph (Outlook / Calendar)
# Get from https://portal.azure.com -> App registrations -> your app -> Overview
MS_CLIENT_ID=
# Use "common" for personal Microsoft accounts, or your tenant ID for work/school
MS_TENANT_ID=common
